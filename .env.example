# ══════════════════════════════════════════════════════════════════════════════
# MCP Server — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
MCP_HOST=127.0.0.1
MCP_PORT=9200
MCP_DEBUG=false
MCP_WORKERS=4

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Configure only the providers you intend to use.
# At least one provider must be configured.

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# ── Router Settings ───────────────────────────────────────────────────────────
# Default provider when none specified in request
MCP_DEFAULT_PROVIDER=openai

# Fallback chain (comma-separated). If primary fails, try next.
MCP_FALLBACK_CHAIN=openai,anthropic,ollama

# Request timeout (seconds)
MCP_REQUEST_TIMEOUT=120

# ── Rate Limiting (Application Level) ─────────────────────────────────────────
# Max requests per IP per window
MCP_RATE_LIMIT_REQUESTS=100
MCP_RATE_LIMIT_WINDOW=60

# ── Logging ───────────────────────────────────────────────────────────────────
MCP_LOG_LEVEL=INFO
MCP_LOG_FILE=/var/log/mcp/mcp.log
MCP_LOG_FORMAT=json

# ── Monitoring ────────────────────────────────────────────────────────────────
# Enable metrics collection
MCP_METRICS_ENABLED=true

# Admin dashboard password (Basic Auth)
MCP_ADMIN_USER=admin
MCP_ADMIN_PASSWORD=changeme

# ── Security ──────────────────────────────────────────────────────────────────
# API Key for authenticating clients (optional)
MCP_API_KEY=

# Allowed origins for CORS (comma-separated)
MCP_CORS_ORIGINS=*
